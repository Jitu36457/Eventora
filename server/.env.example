PORT=5000

MONGO_URI=mongodb://username:password@host:port/database

# Gmail Account (must be a @gmail.com address)
EMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Factor Authentication enabled on Google account
EMAIL_PASS=your-app-password-here

# Use a strong secret key (min 32 chars recommended)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Development or production
NODE_ENV=development

# Optional: Ethereal test email (for development without Gmail)
# ETHEREAL_USER=
# ETHEREAL_PASS=
